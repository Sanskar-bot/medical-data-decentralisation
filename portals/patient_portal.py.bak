    <div id="scan-not-logged" class="alert alert-info">ℹ️ Load your profile first before scanning.</div>
    <div id="scan-logged" style="display:none">
      <div class="card">
        <div class="card-title">Step 1 — Enter Doctor Code</div>
        <p style="color:var(--muted);font-size:13px;margin-bottom:16px">Scan the doctor's QR with your phone camera app — it will show a code. Or ask the doctor for their code directly.</p>
        <div class="form-grid">
          <div>
            <label>Doctor Code (from QR)</label>
            <input id="scan-dcode" placeholder="e.g. 7e7878c3" oninput="lookupDoctor()" />
          </div>
          <div id="scan-doctor-preview" style="display:none" class="alert alert-success" id="doc-preview"></div>
        </div>
      </div>

      <div class="card" id="scan-step2" style="display:none">
        <div class="card-title">Step 2 — Confirm & Transfer (like entering UPI PIN)</div>
        <div id="scan-doc-info" style="margin-bottom:20px;padding:16px;background:var(--green3);border-radius:10px;border:1px solid var(--border)"></div>
        <div class="form-grid">
          <div>
            <label>Your Password 🔐</label>
            <input id="scan-pw" type="password" placeholder="Enter your local password to unlock your data" />
          </div>
          <div style="background:#fff8e1;border:1px solid #ffe082;border-radius:10px;padding:14px">
            <div style="font-weight:600;font-size:13px;color:#7a5a00;margin-bottom:6px">⚠️ What will happen:</div>
            <div style="font-size:12px;color:#7a5a00;line-height:1.7">
              • Your medical record will be encrypted<br>
              • Only this doctor can decrypt it<br>
              • Access expires automatically in <strong>24 hours</strong><br>
              • You can deny future requests anytime
            </div>
          </div>
          <button class="btn btn-primary" id="scan-transfer-btn" onclick="transferToDoctor()">
            🔐 Confirm & Transfer Record
          </button>
        </div>
