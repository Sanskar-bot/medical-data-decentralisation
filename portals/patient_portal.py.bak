</main>
</div>

<!-- APPROVE MODAL -->
<div class="modal-bg" id="approve-modal">
  <div class="modal">
    <h3>🩺 Doctor Access Request</h3>
    <div id="modal-doctor-info" style="margin-bottom:20px"></div>
    <div><label>Your Password (to unlock key)</label><input id="modal-pw" type="password" placeholder="Enter your local password" /></div>
    <div style="display:flex;gap:10px;margin-top:20px;flex-wrap:wrap">
      <button class="btn btn-primary" id="approve-btn" onclick="submitApprove()">✅ Approve (24h Access)</button>
      <button class="btn btn-danger" onclick="submitDeny()">❌ Deny</button>
      <button class="btn btn-outline" onclick="closeModal()">Cancel</button>
    </div>
  </div>
