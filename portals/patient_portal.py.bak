        <button class="tab active" onclick="filterReqs('pending')" id="tab-pending">⏳ Pending</button>
        <button class="tab" onclick="filterReqs('approved')" id="tab-approved">✅ Approved</button>
        <button class="tab" onclick="filterReqs('denied')" id="tab-denied">❌ Denied</button>
      </div>
      <button class="btn btn-outline" onclick="loadRequests()">↻ Refresh</button>
    </div>
    <div id="requests-list"></div>
  </div>


  <!-- SCAN QR PAGE -->
  <div class="page" id="page-scan">
