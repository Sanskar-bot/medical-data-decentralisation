<script>

// ── SCAN / QR TRANSFER ────────────────────────────────────────────────────
let scannedDoctorCode = null;

function initScan() {
  if (!S.logged) {
    document.getElementById('scan-not-logged').style.display = 'block';
    document.getElementById('scan-logged').style.display = 'none';
  } else {
    document.getElementById('scan-not-logged').style.display = 'none';
    document.getElementById('scan-logged').style.display = 'block';
  }
  document.getElementById('scan-result').innerHTML = '';
  document.getElementById('scan-step2').style.display = 'none';
  document.getElementById('scan-dcode').value = '';
}

async function lookupDoctor() {
  const code = document.getElementById('scan-dcode').value.trim();
  if (code.length < 6) { document.getElementById('scan-step2').style.display = 'none'; return; }
  // fetch doctor public key from backend to confirm they exist
  try {
    const res = await fetch('/api/lookup_doctor', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ doctor_code: code })
    });
    const d = await res.json();
    if (!res.ok || !d.found) {
      document.getElementById('scan-step2').style.display = 'none';
      return;
    }
    scannedDoctorCode = code;
    document.getElementById('scan-doc-info').innerHTML = `
      <div style="font-size:13px">
        <div style="font-weight:700;font-size:15px;margin-bottom:6px">🩺 ${d.name || 'Doctor'}</div>
        ${d.specialization ? '<div>Specialization: <strong>' + d.specialization + '</strong></div>' : ''}
        ${d.hospital ? '<div>Hospital: <strong>' + d.hospital + '</strong></div>' : ''}
        <div style="margin-top:6px;color:var(--muted);font-size:11px">Code: ${code}</div>
      </div>`;
    document.getElementById('scan-step2').style.display = 'block';
  } catch(e) {
    document.getElementById('scan-step2').style.display = 'none';
  }
}

async function transferToDoctor() {
  if (!S.logged) return alert('Load your profile first.');
  if (!scannedDoctorCode) return alert('Enter a valid doctor code first.');
  const pw = document.getElementById('scan-pw').value;
  if (!pw) return alert('Enter your password — this is your security PIN.');

  const btn = document.getElementById('scan-transfer-btn');
  btn.disabled = true; btn.innerHTML = '<span class="spin"></span> Encrypting & transferring...';
  document.getElementById('scan-result').innerHTML = '';

  try {
    const res = await fetch('/api/qr_transfer', {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify({
        profile_code: S.code,
        doctor_code: scannedDoctorCode,
        password: pw
      })
    });
    const d = await res.json();
    if (!res.ok) throw new Error(d.error || 'Transfer failed');
    document.getElementById('scan-result').innerHTML = `
      <div class="alert alert-success">
        ✅ <strong>Record transferred successfully!</strong><br>
        Dr. ${scannedDoctorCode} can now view your record for 24 hours.
        Access will expire automatically after that.
      </div>`;
    document.getElementById('scan-step2').style.display = 'none';
    document.getElementById('scan-dcode').value = '';
    scannedDoctorCode = null;
  } catch(e) {
    document.getElementById('scan-result').innerHTML = `<div class="alert alert-error">❌ ${e.message}</div>`;
  } finally {
    btn.disabled = false; btn.textContent = '🔐 Confirm & Transfer Record';
  }
}

// ── state ──────────────────────────────────────────────────────────────────
let S = { code:'', name:'', email:'', logged:false };
let allReqs = [], currentFilter = 'pending', activeReq = null;

// ── nav ────────────────────────────────────────────────────────────────────
function nav(page) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('page-' + page).classList.add('active');
  document.getElementById('nb-' + page)?.classList.add('active');
  if (page === 'requests') loadRequests();
  if (page === 'record') showRecord();
  if (page === 'scan') initScan();
}

// ── auth state ─────────────────────────────────────────────────────────────
function setLoggedIn(code, name, email) {
  S = { code, name, email, logged:true };
  document.getElementById('home-logged-out').style.display = 'none';
  document.getElementById('home-logged-in').style.display = 'block';
  document.getElementById('hi-code').textContent = code;
  document.getElementById('hi-name').textContent = name || '—';
  document.getElementById('hi-email').textContent = email || '—';
  document.getElementById('sidebar-profile').style.display = 'block';
  document.getElementById('sp-name').textContent = name || code;
  document.getElementById('sp-code').textContent = code;
}

function logout() {
  S = { code:'', name:'', email:'', logged:false };
  document.getElementById('home-logged-out').style.display = 'block';
  document.getElementById('home-logged-in').style.display = 'none';
  document.getElementById('sidebar-profile').style.display = 'none';
  nav('home');
}

// ── register ───────────────────────────────────────────────────────────────
async function register() {
  const name = document.getElementById('r-name').value.trim();
  const age  = document.getElementById('r-age').value.trim();
  const email= document.getElementById('r-email').value.trim();
  const notes= document.getElementById('r-notes').value.trim();
  const pw   = document.getElementById('r-pw').value;
  const pw2  = document.getElementById('r-pw2').value;

  if (!name) return alert('Name is required.');
  if (!pw)   return alert('Password is required.');
  if (pw !== pw2) return alert('Passwords do not match.');

  const btn = document.getElementById('reg-btn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spin"></span> Encrypting & registering...';
  document.getElementById('reg-result').innerHTML = '';

  try {
    const res = await fetch('/api/register', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ name, age, email, notes, password:pw })
    });
    const d = await res.json();
    if (!res.ok) throw new Error(d.error || 'Registration failed');

    document.getElementById('reg-result').innerHTML = `
      <div class="alert alert-success">
        ✅ Profile created successfully! Your profile code is below — save it safely.
      </div>
      <div class="card">
        <div class="card-title">Your Profile Code</div>
        <div class="code-display">${d.profile_code}</div>
        <p style="color:var(--muted);font-size:13px;margin-top:12px">
          ⚠️ Save this code! You'll need it every time you log in. 
          Store it alongside your password in a safe place.
        </p>
        <div style="margin-top:16px">
          <button class="btn btn-primary" onclick="nav('home')">Go to Dashboard →</button>
        </div>
      </div>`;
    document.getElementById('reg-form-card').style.display = 'none';
    setLoggedIn(d.profile_code, name, email);
  } catch(e) {
    document.getElementById('reg-result').innerHTML = `<div class="alert alert-error">❌ ${e.message}</div>`;
  } finally {
    btn.disabled = false;
    btn.textContent = '✨ Create My Profile';
  }
}

// ── load profile ───────────────────────────────────────────────────────────
async function loadProfile() {
  const code = document.getElementById('l-code').value.trim();
  const pw   = document.getElementById('l-pw').value;
  if (!code || !pw) return alert('Profile code and password are required.');

  document.getElementById('login-result').innerHTML = '';
  try {
    const res = await fetch('/api/load_profile', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ profile_code:code, password:pw })
    });
    const d = await res.json();
    if (!res.ok) throw new Error(d.error || 'Failed to load profile');

    setLoggedIn(code, d.name, d.email);
    document.getElementById('login-result').innerHTML = `<div class="alert alert-success">✅ Profile loaded! Welcome back, ${d.name || code}.</div>`;
    setTimeout(() => nav('home'), 1200);
  } catch(e) {
    document.getElementById('login-result').innerHTML = `<div class="alert alert-error">❌ ${e.message}</div>`;
  }
}

// ── record view ────────────────────────────────────────────────────────────
async function showRecord() {
  const box = document.getElementById('record-content');
  if (!S.logged) { box.innerHTML = '<div class="alert alert-info">ℹ️ Load your profile first.</div>'; return; }
  try {
    const res = await fetch(`/api/record/${S.code}`);
    const d = await res.json();
    if (!res.ok) throw new Error(d.error);
    const rec = d.record;
    box.innerHTML = `<div class="card">
      <div class="card-title">Decrypted Record (local only)</div>
      ${Object.entries(rec).filter(([k,v])=>v).map(([k,v])=>`
        <div class="record-field">
          <div class="record-key">${k}</div>
          <div class="record-val">${v}</div>
        </div>`).join('')}
    </div>`;
  } catch(e) {
    box.innerHTML = `<div class="alert alert-error">❌ ${e.message}</div>`;
  }
}

// ── requests ───────────────────────────────────────────────────────────────
async function loadRequests() {
  const box = document.getElementById('requests-list');
  document.getElementById('req-alert').innerHTML = '';
  if (!S.logged) {
    box.innerHTML = '<div class="alert alert-info">ℹ️ Load your profile first to see requests.</div>';
    return;
  }
  box.innerHTML = '<div class="empty"><div class="empty-icon">⏳</div><p>Loading...</p></div>';
  try {
    const res = await fetch(`/api/requests/${S.code}`);
    const d = await res.json();
    if (!res.ok) throw new Error(d.error);
    allReqs = d.requests;
    renderReqs();
  } catch(e) {
    box.innerHTML = `<div class="alert alert-error">❌ ${e.message}</div>`;
  }
}

function filterReqs(f) {
  currentFilter = f;
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('tab-' + f).classList.add('active');
  renderReqs();
}

function renderReqs() {
  const box = document.getElementById('requests-list');
  const list = allReqs.filter(r => r.status === currentFilter);
  if (!list.length) {
    box.innerHTML = `<div class="empty"><div class="empty-icon">${currentFilter==='pending'?'🔔':currentFilter==='approved'?'✅':'❌'}</div><p>No ${currentFilter} requests.</p></div>`;
    return;
  }
  box.innerHTML = list.map(r => `
    <div class="req-card ${r.status}">
      <div class="req-info">
        <h4>🩺 Dr. ${r.doctor_name || r.doctor_code}</h4>
        <p>${r.doctor_specialization ? r.doctor_specialization + ' • ' : ''}${r.doctor_hospital || ''}</p>
        <p style="margin-top:4px;font-size:11px;color:var(--muted)">
          Requested: ${new Date(r.timestamp).toLocaleString()}
        </p>
      </div>
      <div class="req-actions">
        <span class="badge badge-${r.status}">${r.status}</span>
        ${r.status==='pending' ? `<button class="btn btn-primary" onclick="openApprove('${r.request_id}')">Review</button>` : ''}
      </div>
    </div>`).join('');
}

// ── approve / deny ─────────────────────────────────────────────────────────
function openApprove(reqId) {
  activeReq = allReqs.find(r => r.request_id === reqId);
  if (!activeReq) return;
  document.getElementById('modal-doctor-info').innerHTML = `
    <div class="record-field"><div class="record-key">Doctor</div><div class="record-val">${activeReq.doctor_name || activeReq.doctor_code}</div></div>
    <div class="record-field"><div class="record-key">Specialization</div><div class="record-val">${activeReq.doctor_specialization || '—'}</div></div>
    <div class="record-field"><div class="record-key">Hospital</div><div class="record-val">${activeReq.doctor_hospital || '—'}</div></div>
    <div class="record-field"><div class="record-key">Access Duration</div><div class="record-val">24 hours</div></div>`;
  document.getElementById('modal-pw').value = '';
  document.getElementById('approve-modal').classList.add('open');
}

function closeModal() {
  document.getElementById('approve-modal').classList.remove('open');
  activeReq = null;
}

async function submitApprove() {
  const pw = document.getElementById('modal-pw').value;
  if (!pw) return alert('Password required.');
  const btn = document.getElementById('approve-btn');
  btn.disabled = true; btn.innerHTML = '<span class="spin"></span> Encrypting...';

  try {
    const res = await fetch('/api/approve', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ profile_code:S.code, request_id:activeReq.request_id,
        doctor_code:activeReq.doctor_code, doctor_public_pem:activeReq.doctor_public_pem, password:pw })
    });
    const d = await res.json();
    if (!res.ok) throw new Error(d.error || 'Approval failed');
    closeModal();
    document.getElementById('req-alert').innerHTML = '<div class="alert alert-success">✅ Access approved! The doctor can now view your record for 24 hours.</div>';
    await loadRequests();
  } catch(e) {
    alert('❌ ' + e.message);
  } finally {
    btn.disabled = false; btn.textContent = '✅ Approve (24h Access)';
  }
}

async function submitDeny() {
  const btn = document.getElementById('approve-btn');
  btn.disabled = true;
  try {
    const res = await fetch('/api/deny', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ request_id:activeReq.request_id })
    });
    const d = await res.json();
    if (!res.ok) throw new Error(d.error);
    closeModal();
    document.getElementById('req-alert').innerHTML = '<div class="alert alert-warn">🚫 Request denied.</div>';
    await loadRequests();
  } catch(e) { alert('Error: ' + e.message); }
  finally { btn.disabled = false; }
}
</script>
</body>
</html>"""

# ── API routes ─────────────────────────────────────────────────────────────
@app.route("/")
def index():
    return HTML

@app.route("/api/register", methods=["POST", "OPTIONS"])
def api_register():
    if request.method == "OPTIONS": return jsonify({}), 200
    d = request.get_json(force=True)
    name, age, email = d.get("name",""), d.get("age",""), d.get("email","")
    notes, pw = d.get("notes",""), d.get("password","")

    if not name: return jsonify({"error":"Name is required"}), 400
    if not pw:   return jsonify({"error":"Password is required"}), 400

    # generate keys + encrypt record
    priv, pub = generate_rsa_keypair()
    K_data    = generate_aes_key()
    record    = {"name":name,"age":age,"email":email,"notes":notes}
    plain     = json.dumps(record, ensure_ascii=False).encode()
    enc       = aesgcm_encrypt(K_data, plain)
    to_sign   = (enc["nonce"] + "|" + enc["ciphertext"]).encode()
    sig       = rsa_sign(priv, to_sign)

    # protect K_data with password
    kek, salt   = derive_kek_from_password(pw)
    wrapped_k   = wrap_key_with_kek(kek, K_data)
    priv_pem    = rsa_serialize_private(priv)
    pub_pem     = rsa_serialize_public(pub)

    # profile code
    profile_code = b64encode(os.urandom(6)).decode().replace("=","").replace("/","_")
    pdir = user_dir(profile_code)
    os.makedirs(pdir, exist_ok=True)

    local = {
        "profile_code": profile_code,
        "patient_details": record,
        "patient_public_pem": pub_pem.decode(),
        "encrypted_record": enc,
        "signature": sig,
        "key_protection": {"wrapped_k": wrapped_k, "salt_b64": b64encode(salt).decode()}
    }
    with open(user_json(profile_code), "w") as f: json.dump(local, f, indent=2)
    with open(os.path.join(pdir, "patient_private.pem"), "wb") as f: f.write(priv_pem)
    with open(os.path.join(pdir, "patient_public.pem"),  "wb") as f: f.write(pub_pem)

    # upload to backend
    try:
        http.post(f"{BACKEND}/register_user",
            json={"profile_code":profile_code,"encrypted_record":enc,
                  "signature":sig,"patient_public_pem":pub_pem.decode()},
            headers=bh(), timeout=8)
    except Exception as e:
        print(f"[warn] backend upload failed: {e}")

    return jsonify({"profile_code": profile_code})

@app.route("/api/load_profile", methods=["POST","OPTIONS"])
def api_load_profile():
    if request.method == "OPTIONS": return jsonify({}), 200
    d = request.get_json(force=True)
    code, pw = d.get("profile_code","").strip(), d.get("password","")
    uf = user_json(code)
    if not os.path.exists(uf):
        return jsonify({"error":"Profile not found on this machine. Register first."}), 404
    with open(uf) as f: local = json.load(f)
    kp = local.get("key_protection") or {}
    if kp.get("wrapped_k"):
        try:
            salt = b64decode(kp["salt_b64"])
            kek, _ = derive_kek_from_password(pw, salt=salt)
            unwrap_key_with_kek(kek, kp["wrapped_k"])  # just validate password
        except Exception:
            return jsonify({"error":"Wrong password."}), 401
    rec = local.get("patient_details", {})
    return jsonify({"name": rec.get("name",""), "email": rec.get("email","")})

@app.route("/api/record/<code>")
def api_record(code):
    uf = user_json(code)
    if not os.path.exists(uf): return jsonify({"error":"Profile not found"}), 404
    with open(uf) as f: local = json.load(f)
    rec = local.get("patient_details", {})
    return jsonify({"record": rec})

@app.route("/api/requests/<code>")
def api_requests(code):
    try:
        r = http.get(f"{BACKEND}/active_requests", headers=bh(), timeout=8)
        all_r = r.json() if r.ok else []
    except Exception:
        return jsonify({"error":"Cannot reach backend server"}), 502

    mine = [x for x in all_r if x.get("profile_code") == code]

    # try to decrypt doctor profile from each request
    uf = user_json(code)
    priv = None
    if os.path.exists(uf):
        pdir = user_dir(code)
        pk = os.path.join(pdir, "patient_private.pem")
        if os.path.exists(pk):
            try:
                priv = rsa_load_private(open(pk,"rb").read())
            except Exception:
                pass

    result = []
    for req in mine:
        entry = {
            "request_id": req.get("request_id"),
            "doctor_code": req.get("doctor_code"),
            "status": req.get("status","pending"),
            "timestamp": req.get("timestamp",""),
            "doctor_public_pem": req.get("doctor_public_pem",""),
            "doctor_name": None, "doctor_specialization": None, "doctor_hospital": None,
        }
        enc_b64 = req.get("encrypted_doctor_profile_b64")
        if enc_b64 and priv:
            try:
                raw = rsa_unwrap_key(priv, enc_b64)
                profile = json.loads(raw.decode())
                entry["doctor_name"] = profile.get("name")
                entry["doctor_specialization"] = profile.get("specialization")
                entry["doctor_hospital"] = profile.get("hospital")
            except Exception:
                pass
        result.append(entry)
    return jsonify({"requests": result})

@app.route("/api/approve", methods=["POST","OPTIONS"])
def api_approve():
    if request.method == "OPTIONS": return jsonify({}), 200
    d = request.get_json(force=True)
    code      = d.get("profile_code","")
    req_id    = d.get("request_id","")
    doc_code  = d.get("doctor_code","")
    doc_pub   = d.get("doctor_public_pem","")
    pw        = d.get("password","")

    uf = user_json(code)
    if not os.path.exists(uf): return jsonify({"error":"Profile not found"}), 404
    with open(uf) as f: local = json.load(f)

    kp = local.get("key_protection",{})
    try:
        salt  = b64decode(kp["salt_b64"])
        kek,_ = derive_kek_from_password(pw, salt=salt)
        K_data = unwrap_key_with_kek(kek, kp["wrapped_k"])
    except Exception:
        return jsonify({"error":"Wrong password"}), 401

    # wrap K_data for doctor
    from datetime import timedelta
    try:
        doc_pub_obj = rsa_load_public(doc_pub.encode())
        T = os.urandom(32)
        enc_kdata = aesgcm_encrypt(T, K_data)
        wrapped_T = rsa_wrap_key(doc_pub_obj, T)
        expires   = (datetime.now(timezone.utc) + timedelta(hours=24)).isoformat()
    except Exception as e:
        return jsonify({"error":f"Crypto error: {e}"}), 500

    try:
        r = http.post(f"{BACKEND}/approve_request",
            json={"request_id":req_id,"doctor_code":doc_code,"patient_code":code,
                  "wrapped_key":wrapped_T,"encrypted_kdata_with_temp":enc_kdata,
                  "temp_key_expires_at":expires},
            headers=bh(), timeout=8)
        if not r.ok: return jsonify({"error":r.text}), r.status_code
    except Exception as e:
        return jsonify({"error":str(e)}), 502

    return jsonify({"status":"ok"})

@app.route("/api/deny", methods=["POST","OPTIONS"])
def api_deny():
    if request.method == "OPTIONS": return jsonify({}), 200
    d = request.get_json(force=True)
    try:
        r = http.post(f"{BACKEND}/update_request_status",
            json={"request_id":d.get("request_id"),"status":"denied"},
            headers=bh(), timeout=8)
        return jsonify({"status":"ok"}) if r.ok else jsonify({"error":r.text}), r.status_code
    except Exception as e:
        return jsonify({"error":str(e)}), 502


@app.route("/api/lookup_doctor", methods=["POST","OPTIONS"])
def api_lookup_doctor():
    if request.method == "OPTIONS": return jsonify({}), 200
    d    = request.get_json(force=True)
    code = d.get("doctor_code","").strip()
    # check backend has this doctor
    try:
        r = http.get(f"{BACKEND}/active_requests", headers=bh(), timeout=6)
        # doctor lookup: check if doctor folder exists locally or just confirm via server
        # look in local doctor Doctors folder for any matching code
        doctors_dir = os.path.join(ROOT, "doctor", "Doctors")
        if os.path.exists(doctors_dir):
            for folder in os.listdir(doctors_dir):
                meta_path = os.path.join(doctors_dir, folder, "doctor_data.json")
                if os.path.exists(meta_path):
                    try:
                        m = json.load(open(meta_path))
                        if m.get("doctor_code") == code:
                            return jsonify({"found": True, "name": m.get("name",""),
                                "specialization": m.get("specialization",""),
                                "hospital": m.get("hospital","")})
                    except: pass
        # also check server Doctors folder
        server_doc = os.path.join(ROOT, "server", "Doctors", f"{code}.json")
        if os.path.exists(server_doc):
            return jsonify({"found": True, "name": "", "specialization": "", "hospital": ""})
        return jsonify({"found": False}), 404
    except Exception as e:
        return jsonify({"found": False, "error": str(e)}), 502

@app.route("/api/qr_transfer", methods=["POST","OPTIONS"])
def api_qr_transfer():
    """Patient scans doctor QR and directly transfers encrypted record — like a UPI payment."""
    if request.method == "OPTIONS": return jsonify({}), 200
    d        = request.get_json(force=True)
    pat_code = d.get("profile_code","")
    doc_code = d.get("doctor_code","")
    pw       = d.get("password","")

    # 1. load patient K_data
    uf = user_json(pat_code)
    if not os.path.exists(uf): return jsonify({"error":"Patient profile not found"}), 404
    with open(uf) as f: local = json.load(f)
    kp = local.get("key_protection",{})
    try:
        salt   = b64decode(kp["salt_b64"])
        kek,_  = derive_kek_from_password(pw, salt=salt)
        K_data = unwrap_key_with_kek(kek, kp["wrapped_k"])
    except Exception:
        return jsonify({"error":"Wrong password"}), 401

    # 2. fetch doctor public key from backend
    try:
        r = http.get(f"{BACKEND}/register_doctor", headers=bh(), timeout=6)
    except: pass
    # get doctor pub from local Doctors folder
    doc_pub_pem = None
    doctors_dir = os.path.join(ROOT, "doctor", "Doctors")
    if os.path.exists(doctors_dir):
        for folder in os.listdir(doctors_dir):
            meta_path = os.path.join(doctors_dir, folder, "doctor_data.json")
            pub_path  = os.path.join(doctors_dir, folder, "doctor_public.pem")
            if os.path.exists(meta_path) and os.path.exists(pub_path):
                try:
                    m = json.load(open(meta_path))
                    if m.get("doctor_code") == doc_code:
                        doc_pub_pem = open(pub_path,"rb").read().decode()
                        break
                except: pass

    if not doc_pub_pem:
        # try fetching from server Doctors folder
        server_doc_path = os.path.join(ROOT, "server", "Doctors", f"{doc_code}.json")
        if os.path.exists(server_doc_path):
            try:
                sd = json.load(open(server_doc_path))
                doc_pub_pem = sd.get("public_pem","")
            except: pass

    if not doc_pub_pem:
        return jsonify({"error":"Doctor not found. Make sure the doctor is registered on this system."}), 404

    # 3. wrap K_data for doctor (same as approve flow)
    from datetime import timedelta
    try:
        doc_pub_obj = rsa_load_public(doc_pub_pem.encode())
        T           = os.urandom(32)
        enc_kdata   = aesgcm_encrypt(T, K_data)
        wrapped_T   = rsa_wrap_key(doc_pub_obj, T)
        expires     = (datetime.now(timezone.utc) + timedelta(hours=24)).isoformat()
    except Exception as e:
        return jsonify({"error":f"Encryption failed: {e}"}), 500

    # 4. we need a request_id — create a fake approved request directly
    # First send a request on behalf of doctor, then approve it immediately
    pat_priv_path = os.path.join(user_dir(pat_code), "patient_private.pem")
    if not os.path.exists(pat_priv_path):
        return jsonify({"error":"Patient private key not found locally"}), 500

    # get doctor public key object to encrypt profile
    profile_bytes = json.dumps({"doctor_code": doc_code, "name": "QR Transfer",
        "specialization":"","hospital":""}, separators=(",",":")).encode()
    enc_b64 = rsa_wrap_key(doc_pub_obj, profile_bytes)

    try:
        # post access request
        rr = http.post(f"{BACKEND}/request_access_simple/{pat_code}",
            json={"doctor_code":doc_code,"doctor_public_pem":doc_pub_pem,
                  "encrypted_doctor_profile_b64":enc_b64},
            headers=bh(), timeout=8)
        rd = rr.json()
        req_id = rd.get("request_id") or rd.get("request",{}).get("request_id")
        if not req_id:
            # duplicate pending — find it
            ar = http.get(f"{BACKEND}/active_requests", headers=bh(), timeout=6).json()
            found = next((x for x in ar if x.get("profile_code")==pat_code
                          and x.get("doctor_code")==doc_code and x.get("status")=="pending"), None)
            req_id = found["request_id"] if found else None
        if not req_id:
            return jsonify({"error":"Could not create access request"}), 500

        # immediately approve with wrapped key
        ra = http.post(f"{BACKEND}/approve_request",
            json={"request_id":req_id,"doctor_code":doc_code,"patient_code":pat_code,
                  "wrapped_key":wrapped_T,"encrypted_kdata_with_temp":enc_kdata,
                  "temp_key_expires_at":expires},
            headers=bh(), timeout=8)
        if not ra.ok:
            return jsonify({"error":ra.text}), ra.status_code
    except Exception as e:
        return jsonify({"error":str(e)}), 502

    return jsonify({"status":"ok","expires_at":expires})

if __name__ == "__main__":
    print("  Patient Portal → http://127.0.0.1:5001")
    app.run(host="127.0.0.1", port=5001, debug=False)
