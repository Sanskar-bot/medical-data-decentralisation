      <div class="card" style="background:var(--green3);border:1px solid var(--border)">
        <div class="card-title">How It Works</div>
        <div style="display:flex;gap:16px;flex-wrap:wrap">
          <div style="flex:1;min-width:200px;text-align:center;padding:12px">
            <div style="font-size:28px">📲</div>
            <div style="font-weight:600;font-size:13px;margin-top:6px">Scan QR</div>
            <div style="color:var(--muted);font-size:12px">Like scanning a UPI QR</div>
